# Server Configuration
PORT=3003
NODE_ENV=production
LOG_LEVEL=info

# CORS Configuration
# Comma-separated list of allowed origins
# Use "*" for development only (NOT recommended for production)
ALLOWED_ORIGINS=https://app.betterbookmark.me,https://www.betterbookmark.me

# Firebase Configuration (Client SDK - for Realtime Database)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Firebase Admin SDK (for server-side authentication)
# Option 1: Use service account JSON file path
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json

# Option 2: Use individual credentials (if not using service account file)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"

# ChromaDB Configuration
CHROMA_API_URL=http://localhost:8000
CHROMA_API_KEY=your_chroma_api_key
CHROMA_TENANT=your_tenant_id
CHROMA_DATABASE=your_database_name
COLLECTION_NAME=bookmarks_production

# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here

# Optional: JWT Secret (if using custom JWT tokens instead of Firebase)
# JWT_SECRET=your_jwt_secret_key_here

# Optional: Chroma Persistence Directory (for local deployments)
# CHROMA_PERSIST_DIRECTORY=/path/to/chromadb/data
